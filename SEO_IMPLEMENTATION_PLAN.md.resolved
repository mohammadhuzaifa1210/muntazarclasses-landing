  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.0553",
    "longitude": "72.9183"
  },
  "areaServed": ["Govandi", "Govandi West", "Govandi East", "Baiganwadi", "Deonar", "Chembur", "Mankhurd"],
